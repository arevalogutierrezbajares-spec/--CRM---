    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/ui": "^4.1.7",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.30.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
