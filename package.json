{
  "name": "agb-crm",
  "version": "0.1.0",
  "private": true,
  "description": "Internal CRM for Arevalo Gutierrez Bajares — chief-of-staff tool for CaneyCloud + VAV + BD warm network + project tracking.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx db/seed.ts",
    "db:seed-demo": "tsx scripts/seed-demo.ts",
    "obsidian:sync": "tsx scripts/obsidian-sync.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:db": "bash scripts/test-db.sh",
    "test:integration": "DATABASE_URL=postgresql://agb@localhost:54329/agb_test vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "test:all": "vitest run && DATABASE_URL=postgresql://agb@localhost:54329/agb_test vitest run --config vitest.integration.config.ts && playwright test",
    "verify": "tsx scripts/verify.ts"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.49.0",
    "@tanstack/react-virtual": "^3.13.26",
