# ──────────────────────────────────────────────────────────────────────────
# AGB CRM — Environment Variables
# Copy to .env.local and fill in actual values
# ──────────────────────────────────────────────────────────────────────────

# Supabase (project provisioned via `supabase projects create`)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Direct DB connection for Drizzle migrations + seed
# Format: postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
DATABASE_URL=

# LLM provider (Phase 4 — Active Brain)
ANTHROPIC_API_KEY=
# Optional: Vercel AI Gateway URL when wired
VERCEL_AI_GATEWAY_URL=
# Default model for call sites that do not pass model explicitly.
# `claude-haiku-4-5` is much cheaper and preferred for most CRM surfaces.
ANTHROPIC_DEFAULT_MODEL=claude-haiku-4-5
# Daily spend guardrail for all Anthropic traffic in this process.
# Set to 3 to enforce a rough $3/day max (assuming Haiku pricing).
ANTHROPIC_DAILY_BUDGET_USD=3
# Optional per-day token fallback guardrail (legacy-capable alias:
# AGB_WA_DAILY_TOKEN_CAP is still read if set).
ANTHROPIC_DAILY_TOKEN_CAP=
# Optional: per-model override for real-time price changes (USD per 1M tokens)
# e.g. {"claude-haiku-4-5":{"input":0.8,"output":4}}
ANTHROPIC_PRICE_PER_1M_USD=

# Voice transcription (Phase 3 — Capture)
# Preferred: Groq Whisper (whisper-large-v3-turbo) — ~6x cheaper + faster than
# OpenAI Whisper, used for WhatsApp voice notes. Get one at console.groq.com/keys
GROQ_API_KEY=
# Optional override of the Groq model (default: whisper-large-v3-turbo)
GROQ_WHISPER_MODEL=
# Fallback transcription if GROQ_API_KEY is unset
OPENAI_API_KEY=

# Live call recorder (/record) — Deepgram streaming transcription
DEEPGRAM_API_KEY=

# JARVIS voice clips (scripts/gen-greetings.ts → public/greetings/*.mp3 + public/jarvis/*.mp3)
# Required to render the voice clips. Get one at elevenlabs.io → Profile → API key
ELEVENLABS_API_KEY=
# Optional: override the voice (default wDsJlOXPqcvIUKdLXjDs = dedicated JARVIS voice)
ELEVENLABS_VOICE_ID=
# Optional: override the TTS model (default eleven_multilingual_v2)
ELEVENLABS_MODEL_ID=

# Email send (Phase 4 — Weekly Briefing)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Email intake (Phase 3 — email-forward capture)
POSTMARK_INBOUND_WEBHOOK_SECRET=

# Company mailbox provider (Email module)
MS_GRAPH_TENANT_ID=
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=
EMAIL_GRAPH_WEBHOOK_CLIENT_STATE=

# Zoho Mail provider (Email module; works with Zoho Mail Free via REST API, not IMAP)
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ORGANIZATION_ID=
ZOHO_PROVIDER_TENANT_NAME=Zoho Mail
# Use .eu/.in/.com.au/etc. bases if your Zoho account is not in the US data center.
ZOHO_ACCOUNTS_BASE_URL=https://accounts.zoho.com
ZOHO_MAIL_API_BASE_URL=https://mail.zoho.com/api

# Protected cron routes (/api/cron/*)
CRON_SECRET=

# WhatsApp Business API (Phase 3 — bot)
META_WHATSAPP_PHONE_ID_FOUNDER_1=
META_WHATSAPP_PHONE_ID_FOUNDER_2=
META_WHATSAPP_ACCESS_TOKEN=
META_WHATSAPP_VERIFY_TOKEN=

# Observability
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Platform Management hub (/platforms) — all optional; cards degrade gracefully.
# Override admin base URLs (default: prod domains)
PLATFORM_VAV_URL=
PLATFORM_CANEY_URL=
# VAV live stats (server-only — NEVER expose as NEXT_PUBLIC_)
VAV_SUPABASE_URL=
VAV_SUPABASE_SERVICE_ROLE_KEY=
# CaneyCloud PMS backend base URL (Cloud Run). Used for the /platforms health
# ping AND the posada onboarding intake wizard (POST /api/v1/onboarding/...).
CANEY_PMS_API_URL=

# Credentials Vault (/platforms) — 64 hex chars: openssl rand -hex 32.
# Encrypts stored passwords at rest. Rotating/losing it makes them unreadable.
VAULT_MASTER_KEY=

# xAI (Grok) image generation — partner-room hero images (South America
# nature themes). Optional; the generator UI/tool reports "not configured"
# without it and rooms fall back to the video/aurora hero.
XAI_API_KEY=
# Optional model override (default grok-imagine-image; use
# grok-imagine-image-quality for the hi-fi tier).
XAI_IMAGE_MODEL=
